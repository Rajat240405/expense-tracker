# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OAuth Redirect URL
# Leave blank (or omit) on desktop — window.location.origin is used automatically.
# On mobile dev: set this to your machine's local network IP so the phone can
# reach the redirect URL after Google login.
#   Example (mobile dev):  VITE_APP_URL=http://10.170.247.180:3000
#   Example (production):  VITE_APP_URL=https://yourdomain.com
VITE_APP_URL=
